generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(uuid())
  username     String       @unique
  passwordHash String       @map("password_hash")
  role         Role
  lastLogin    DateTime?    @map("last_login")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  preferences  Json?
  adminCampus  AdminCampus?
  dosen        Dosen?
  mahasiswa    Mahasiswa?
  notifikasi   Notifikasi[]
  staffTU      StaffTU?

  @@map("users")
}

model Mahasiswa {
  id               String            @id @default(uuid())
  userId           String            @unique @map("id_user")
  nama             String
  nim              String            @unique @map("NIM")
  email            String            @unique
  noHp             String?           @map("no_hp")
  semesterAktif    Int               @map("semester_aktif")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  anggotaKelompoks AnggotaKelompok[]
  comments         Comment[]
  deliverable      Deliverable[]
  enrollments      Enrollment[]
  logAktivitas     LogAktivitas[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions      Submission[]

  @@map("mahasiswa")
}

model Dosen {
  id          String       @id @default(uuid())
  userId      String       @unique @map("id_user")
  nama        String
  email       String       @unique
  noHp        String?      @map("no_hp")
  nidn        String       @unique @map("nidn")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  comments    Comment[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mataKuliahs MataKuliah[]

  @@map("dosen")
}

model AdminCampus {
  id        String   @id @default(uuid())
  userId    String   @unique @map("id_user")
  nama      String
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_campus")
}

model StaffTU {
  id        String   @id @default(uuid())
  userId    String   @unique @map("id_user")
  nama      String
  email     String   @unique
  unit      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_tu")
}

model MataKuliah {
  id          String       @id @default(uuid())
  namaMk      String       @map("nama_mk")
  kodeMk      String       @unique @map("kode_mk")
  idDosen     String       @map("id_dosen")
  semester    Int
  tahunAjar   String       @map("tahun_ajar")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  enrollments Enrollment[]
  kelompok    Kelompok[]
  dosen       Dosen        @relation(fields: [idDosen], references: [id])
  proyek      Proyek[]
  tugas       Tugas[]

  @@map("mata_kuliah")
}

model Enrollment {
  id          String     @id @default(uuid())
  idMahasiswa String     @map("id_mahasiswa")
  idMk        String     @map("id_mk")
  semester    Int
  tahunAjar   String     @map("tahun_ajar")
  status      String
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  mahasiswa   Mahasiswa  @relation(fields: [idMahasiswa], references: [id], onDelete: Cascade)
  mataKuliah  MataKuliah @relation(fields: [idMk], references: [id], onDelete: Cascade)

  @@unique([idMahasiswa, idMk, tahunAjar])
  @@index([idMahasiswa, idMk])
  @@map("enrollment")
}

model Tugas {
  id               String        @id @default(uuid())
  idMk             String        @map("id_mk")
  judul            String
  deskripsi        String?
  tanggalDiberikan DateTime      @map("tanggal_diberikan")
  deadline         DateTime
  bobotNilai       Int           @map("bobot_nilai")
  jenis            String
  statusGlobal     String        @map("status_global")
  tipe             String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  comments         Comment[]
  deliverables     Deliverable[]
  submissions      Submission[]
  mataKuliah       MataKuliah    @relation(fields: [idMk], references: [id], onDelete: Cascade)

  @@index([idMk, deadline])
  @@map("tugas")
}

model Proyek {
  id            String        @id @default(uuid())
  idMk          String        @map("id_mk")
  namaProyek    String        @map("nama_proyek")
  deskripsi     String?
  tanggalMulai  DateTime      @map("tanggal_mulai")
  deadlineAkhir DateTime      @map("deadline_akhir")
  progresProyek Int           @default(0) @map("progres_proyek")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deliverables  Deliverable[]
  kelompoks     Kelompok[]
  mataKuliah    MataKuliah    @relation(fields: [idMk], references: [id], onDelete: Cascade)

  @@index([idMk, deadlineAkhir])
  @@map("proyek")
}

model Deliverable {
  id                String     @id @default(uuid())
  idTugas           String?    @map("id_tugas")
  idProyek          String?    @map("id_proyek")
  namaAktivitas     String     @map("nama_aktivitas")
  idPenanggungJawab String?    @map("id_penanggung_jawab")
  status            String
  deadlineKhusus    DateTime?  @map("deadline_khusus")
  persentaseBobot   Int        @map("persentase_bobot")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  penanggungJawab   Mahasiswa? @relation(fields: [idPenanggungJawab], references: [id])
  proyek            Proyek?    @relation(fields: [idProyek], references: [id], onDelete: Cascade)
  tugas             Tugas?     @relation(fields: [idTugas], references: [id], onDelete: Cascade)

  @@map("deliverable")
}

model Kelompok {
  id           String            @id @default(uuid())
  idMk         String            @map("id_mk")
  idProyek     String?           @map("id_proyek")
  namaKelompok String            @map("nama_kelompok")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  anggota      AnggotaKelompok[]
  comments     Comment[]
  mataKuliah   MataKuliah        @relation(fields: [idMk], references: [id], onDelete: Cascade)
  proyek       Proyek?           @relation(fields: [idProyek], references: [id])
  submissions  Submission[]

  @@map("kelompok")
}

model AnggotaKelompok {
  id          String    @id @default(uuid())
  idKelompok  String    @map("id_kelompok")
  idMahasiswa String    @map("id_mahasiswa")
  peran       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  kelompok    Kelompok  @relation(fields: [idKelompok], references: [id], onDelete: Cascade)
  mahasiswa   Mahasiswa @relation(fields: [idMahasiswa], references: [id], onDelete: Cascade)

  @@unique([idKelompok, idMahasiswa])
  @@map("anggota_kelompok")
}

model LogAktivitas {
  id            String    @id @default(uuid())
  idReferensi   String    @map("id_referensi")
  idMahasiswa   String    @map("id_mahasiswa")
  tanggal       DateTime  @default(now())
  catatan       String
  persenProgres Int       @map("persen_progres")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  mahasiswa     Mahasiswa @relation(fields: [idMahasiswa], references: [id], onDelete: Cascade)

  @@map("log_aktivitas")
}

model Submission {
  id          String    @id @default(uuid())
  idTugas     String?   @map("id_tugas")
  idKelompok  String?   @map("id_kelompok")
  idMahasiswa String    @map("id_mahasiswa")
  fileName    String?   @map("file_name")
  fileSize    String?   @map("file_size")
  note        String?
  url         String?
  type        String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  nilai       Int?
  kelompok    Kelompok? @relation(fields: [idKelompok], references: [id], onDelete: Cascade)
  mahasiswa   Mahasiswa @relation(fields: [idMahasiswa], references: [id], onDelete: Cascade)
  tugas       Tugas?    @relation(fields: [idTugas], references: [id], onDelete: Cascade)

  @@index([idTugas, idMahasiswa])
  @@map("submission")
}

model Comment {
  id          String     @id @default(uuid())
  idTugas     String?    @map("id_tugas")
  idKelompok  String?    @map("id_kelompok")
  idMahasiswa String?    @map("id_mahasiswa")
  idDosen     String?    @map("id_dosen")
  text        String
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  dosen       Dosen?     @relation(fields: [idDosen], references: [id], onDelete: Cascade)
  kelompok    Kelompok?  @relation(fields: [idKelompok], references: [id], onDelete: Cascade)
  mahasiswa   Mahasiswa? @relation(fields: [idMahasiswa], references: [id], onDelete: Cascade)
  tugas       Tugas?     @relation(fields: [idTugas], references: [id], onDelete: Cascade)

  @@map("comment")
}

model Notifikasi {
  id         String            @id @default(uuid())
  idUser     String            @map("id_user")
  judul      String
  pesan      String
  jenis      JenisNotifikasi
  waktuKirim DateTime          @default(now()) @map("waktu_kirim")
  statusBaca Boolean           @default(false) @map("status_baca")
  channel    ChannelNotifikasi @default(IN_APP)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  user       User              @relation(fields: [idUser], references: [id], onDelete: Cascade)

  @@index([idUser, statusBaca])
  @@map("notifikasi")
}

enum Role {
  MAHASISWA
  DOSEN
  ADMIN
  STAFF_TU
}

enum JenisNotifikasi {
  DEADLINE
  PROGRES
  INFO
  SISTEM
  BROADCAST
}

enum ChannelNotifikasi {
  IN_APP
  EMAIL
  TELEGRAM
}
