# Database Connection (Supabase / PostgreSQL)
# Ganti detail koneksi berikut dengan kredensial database Supabase Anda
DATABASE_URL="postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres?schema=public&pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres?schema=public"

# Auth.js / NextAuth Configuration
# Generate random 32-character secret key: `openssl rand -base64 33` atau teks acak yang panjang
AUTH_SECRET="your-auth-secret-key-at-least-32-characters"
AUTH_REDIRECT_PROXY_URL="http://localhost:3000"

# Google OAuth (Opsional — untuk fitur "Masuk dengan Google")
# Dapatkan Client ID dan Secret dari: https://console.cloud.google.com/apis/credentials
# Tambahkan Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Telegram Bot (Opsional — untuk notifikasi via Telegram)
# Buat bot baru dengan @BotFather di Telegram untuk mendapatkan token
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# Email (Opsional — notifikasi via Resend)
# Daftar di https://resend.com untuk mendapatkan API key
RESEND_API_KEY="your-resend-api-key"
# Alamat pengirim (verifikasi domain di dashboard Resend untuk hindari spam)
EMAIL_FROM="SIM Tugas <onboarding@resend.dev>"
# Secret untuk mengamankan pemanggilan endpoint cron (GET /api/cron/*)
CRON_SECRET="your-cron-secret"

# Fitur Transisi / Pengembangan
# Set ke "true" untuk bypass database dan menggunakan mock data/data simulasi lokal (default: true)
NEXT_PUBLIC_DEMO_MODE="true"

# SSO Kampus (SAML via BoxyHQ Jackson / LDAP) — OPSIONAL, butuh layanan eksternal
# Aktifkan hanya bila IdP kampus sudah disiapkan. Provider SAML butuh Jackson
# (service terpisah) atau package `@boxyhq/saml` terpasang. Lihat catatan di lib/sso.ts.
SSO_ENABLED="false"
SSO_TYPE="saml"
SSO_LABEL="SSO Kampus"
SSO_ISSUER=""
SSO_CLIENT_ID=""
SSO_CLIENT_SECRET=""
SSO_ENTRY_POINT=""
SSO_CERT=""
